---
import Button from "../components/Button.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Contact from "../components/Contact.astro";
import BurgerMenu from "../components/BurgerMenu.astro";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="https://use.typekit.net/cwl4czb.css" />
    <link rel="stylesheet" href="/src/style/fonts.css" />
    <link rel="stylesheet" href="/src/style/variables.css" />
    <title>Nélia Figuerola</title>
  </head>
  <body>
    <Nav />
    <BurgerMenu />
    <header>
      <img
        class="top"
        src="/assets/icons/top-effect.svg"
        alt=""
        width="111"
        height="97"
      />
      <section class="hero">
        <div class="right-side">
          <h1>Salut, moi c’est Nélia&nbsp;!</h1>
          <h2>Je conçois des interfaces claires, accessibles et sobres.</h2>
        </div>
      </section>
      <img
        class="bottom"
        src="/assets/icons/bottom-effect.svg"
        alt=""
        width="91"
        height="87"
      />
    </header>
    <section class="welcome">
      <div class="welcome__inner">
        <h2>Bienvenue sur mon site</h2>
        <p>
          Ici, vous découvrirez mon profil, mais aussi ma personnalité, car ce
          que j’aime faire, c’est travailler avec ceux qui partagent ma vision
          du travail.
        </p>
        <p>
          J’adore le digital, et j’ai plein de choses à vous présenter. De ma
          veille et mes inspirations, jusqu’aux projets concrets et aboutis.
        </p>
        <div class="welcome__assets">
          <Button title="Découvrir mes projets" link="/mes-projets/" />
          <img
            src="/public/assets/icons/welcome.svg"
            alt=""
            width="78"
            height="68"
          />
        </div>
      </div>
    </section>
    <main>
      <section class="inspi">
        <div class="inspi__assets">
          <h2>Veille et inspirations</h2>
          <img src="/public/assets/icons/heart.svg" alt="" />
        </div>
        <div class="inspi__inner">
          <div class="speakers">
            <h3>Personnalités & Speakers</h3>
            <p>
              Professionnels, amateurs ou artistes, j’aime ouvrir ma veille à
              tous les horizons pour en apprendre toujours, même à petite
              échelle.
            </p>
          </div>
          <div class="design">
            <h3>Typographies & Design</h3>
            <p>
              Je préfère les typos et les designs accessibles. Mais voir des
              designs et typos souvent plus beaux que utiles, me permet de
              garder une inspiration originale.
            </p>
          </div>
          <div class="veille">
            <h3>Veille</h3>
            <p>
              J’ai mis du temps à adapter un système de veille efficace. Flux
              RSS, influenceurs, boards. Aujourd’hui, j’ai préféré tout réunir
              en seul endroit, mon site.
            </p>
          </div>
        </div>
        <Button title="Voir mes inspirations" link="/wip/" />
      </section>
      <Contact />
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    background: var(--primary);
    display: flex;
    flex-wrap: wrap;
    width: min(100% 830px);
    flex-direction: column;
    justify-content: center;
    padding: 30px 0px;
    gap: 80px;
  }

  header {
    display: flex;
    width: min(100% 830px);
    margin: 0 auto;
    padding: 0px 120px;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  header .top {
    align-self: flex-start;
  }

  header .bottom {
    align-self: flex-end;
  }
  h1 {
    color: var(--title);
    font-family: "monotalic";
    font-size: 55px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  h2 {
    color: var(--title);
    font-family: "ABC Favorit Mono Edu";
    font-size: 44px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  h3 {
    color: var(--title);
    font-family: "ABC Favorit Mono Edu";
    font-size: 35px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  p {
    color: var(--text-primary);
    font-family: "Fibra One";
    font-size: 20px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  .hero {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    margin: 0 auto;
  }
  .right-side {
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    align-items: flex-start;
    gap: 50px;
  }

  main {
    display: flex;
    flex-wrap: wrap;
    padding: 0px 120px;
    width: min(100% 1200px);
    margin: 0 auto;
    flex-direction: column;
    align-self: stretch;
    gap: 80px;
  }

  .welcome {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    width: min(100% 1200px);
    background: var(--secondary);
  }
  .welcome__inner {
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    width: 100%;
    gap: 20px;
    padding: 60px 120px;
    box-sizing: border-box;
  }
  .welcome__assets {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
  }

  .inspi {
    display: flex;
    flex-wrap: wrap;
    padding: 60px 0px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 30px;
    align-self: stretch;
  }

  .inspi__assets {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    align-self: stretch;
  }

  .inspi__inner {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    gap: 50px;
  }
  .speakers,
  .design,
  .veille {
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    background-color: var(--secondary);
    gap: 20px;
    justify-content: space-between;
    padding: 30px;
    align-items: flex-start;
    align-self: start;
    border-radius: 10px;
  }

  @media (max-width: 768px) {
    body {
      display: flex;
      padding: 0px 20px;
    }

    .header,
    .main,
    .welcome__inner {
      padding: 0px 50px;
    }
    img {
      display: none;
    }
  }
</style>
