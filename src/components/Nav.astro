---
import Button from "./Button.astro";
---

<nav>
  <button class="nav__burger" aria-label="Ouvrir le menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <ul class="nav__links">
    <li><a href="/">Accueil</a></li>
    <li><a href="/a-propos/">À propos</a></li>
    <li><a href="/mes-projets">Mes projets</a></li>
    <li><a href="/wip">Inspirations</a></li>
    <Button title="Contact" type="button-fill" href="/contact/" />
  </ul>
</nav>

<style>
  nav {
    border-radius: 20px;
    background: var(--secondary);
    display: flex;
    width: fit-content;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: var(--space-s);
    margin: 0 auto;
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    top: 20px;
    z-index: 100;
    box-shadow: 0px 4px 4px 1px rgba(0, 0, 0, 0.25);
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--title, #733635);
    border-radius: 2px;
    transition:
      transform 0.25s,
      opacity 0.25s;
  }

  .nav__burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav__burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav__links {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-s-l);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__links a {
    color: var(--text-primary);
    text-decoration: none;
    font-family: "Fibra One";
    font-size: var(--space-xs-s);
  }

  .nav__links .contact {
    display: flex;
    width: fit-content;
    padding: var(--space-xs);
    justify-content: center;
    align-items: center;
    border-radius: 8px;
    border: 2px solid var(--secondary);
    background: var(--text-primary);
    color: var(--primary);
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    nav {
      border-radius: 16px;
      padding: var(--space-xs-s);
      margin: 0;
      position: fixed;
      left: 85%;
      top: 90%;
      height: fit-content;
    }

    .nav__burger {
      display: flex;
    }

    .nav__links {
      display: none;
      position: absolute;
      top: -100%;
      transform: translateY(-80%) translateX(-50%);
      flex-direction: column;
      align-items: flex-start;
      background: var(--secondary, #ececdc);
      border-radius: 16px;
      padding: var(--space-xs-s);
      gap: var(--space-xs);
    }

    .nav__links.is-open {
      display: flex;
      width: fit-content;
    }

    .nav__links a {
      font-size: var(--step--1);
      padding: var(--space-3xs-2xs);
      border-bottom: 1px solid color-mix(in srgb, var(--title) 15%, transparent);
    }

    .nav__links li:last-child a {
      border-bottom: none;
    }

    .nav__links .contact {
      justify-content: center;
      border-radius: 8px;
    }
  }
</style>

<script>
  const burger = document.querySelector(".nav__burger") as HTMLButtonElement;
  const links = document.querySelector(".nav__links") as HTMLElement;

  burger?.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    links?.classList.toggle("is-open", !open);
  });
</script>
