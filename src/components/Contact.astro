---
import Button from "../components/Button.astro";
---

<section class="contact">
  <h2>Me contacter</h2>
  <p>
    Actuellement en poste, je suis en recherche d'une alternance pour la rentrée
    26-27. Ça serait bête de se louper, alors <b>restons en contact</b> !
  </p>
  <div class="contact__assets">
    <Button title="Me contacter" link="/contact/" />
    <img
      src="/public/assets/icons/contact.svg"
      alt="Contact"
      width="106"
      height="36"
    />
  </div>
</section>

<style>
  h2 {
    color: var(--title);
    font-family: "ABC Favorit Mono Edu";
    font-size: 44px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  p {
    color: var(--text-primary);
    font-family: "Fibra One";
    font-size: 20px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  .contact {
    display: flex;
    flex-wrap: wrap;
    padding: 60px 30px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 30px;
    align-self: stretch;
    background-color: var(--secondary);
    border-radius: 10px;
  }

  .contact__assets {
    display: flex;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
  }

  @media-queries;
</style>
