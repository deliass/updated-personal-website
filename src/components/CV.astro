---
import Button from "../components/Button.astro";
---

<section class="cv">
  <div class="cv__inner">
    <h2>Garder mon CV</h2>
    <p>
      Si mes projets vous plaisent, vous pouvez télécharger mon CV pour garder
      une vue d’ensemble de ma vie professionnelle.
    </p>
    <div class="cv__assets">
      <Button title="Télécharger mon CV" pdfUrl="/figuerola-nelia_CV.pdf" />
      <img src="/public/assets/icons/cv.svg" alt="" width="78" height="68" />
    </div>
  </div>
</section>

<style>
  h2 {
    color: var(--title);
    font-family: "ABC Favorit Mono Edu";
    font-size: 44px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  .cv {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    width: 100%;
    background: var(--secondary);
  }

  .cv__inner {
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    width: 100%;
    gap: 20px;
    padding: 60px 120px;
    box-sizing: border-box;
  }

  .cv__assets {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
  }

  p {
    color: var(--text-primary);
    font-family: "Fibra One";
    font-size: 20px;
    margin-top: 0px;
    margin-bottom: 0px;
  }

  @media (max-width: 768px) {
    img {
      display: none;
    }
  }
</style>
